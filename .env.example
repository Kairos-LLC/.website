# Copy this file to .env.local (Next.js dev) and/or configure the same
# names in your deployment environment (e.g. Vercel project settings).
# Never commit real values — this file documents variable names only.

# --- Supabase project (client-side + server-side) --------------------------

# Public: safe to expose to the browser. Row Level Security policies (see
# Unit 2's migrations) are what actually protect data, not the secrecy of
# these two values. Used by lib/supabase/client.ts and lib/supabase/server.ts.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER prefix this with NEXT_PUBLIC_ and never reference it
# from any Client Component or code that ships to the browser bundle — it
# bypasses Row Level Security entirely. Only use it in trusted server-side
# code (Route Handlers / Server Actions) for privileged operations, via a
# dedicated admin client (not the factories in lib/supabase/client.ts or
# lib/supabase/server.ts, which are scoped to the anon key).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Database (pooled vs. direct) -------------------------------------------
#
# Naming convention established by Unit 3 (see lib/supabase/pooling.md for
# full rationale): explicit KAIROS_-prefixed names instead of the
# Vercel/Prisma defaults (POSTGRES_PRISMA_URL / POSTGRES_URL_NON_POOLING),
# since Kairos does not use the Vercel Postgres integration.

# Pooled connection (Supavisor/PgBouncer, transaction mode, port 6543,
# `?pgbouncer=true`). Used by the running app for normal request-time query
# traffic (API routes, Server Actions, Prisma Client, etc).
KAIROS_DATABASE_URL=postgres://postgres:your-password@your-project-ref.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection (no pooler, port 5432). Used only for schema migrations
# and one-off admin scripts — never point request-time app code at this one.
KAIROS_DIRECT_URL=postgres://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres
